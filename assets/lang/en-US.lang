    fail: "Save failed: {error}"
    ok: "Saved {setting}."

traffic:
  mode:
    auto: "Automatic"
    none: "None"
  host:
    none: "None yet"
    throttling: "Throttled"
    pass: "Passing"
  text:
    status: "Handles request admission, throttling, queueing, delayed retry, and same-site release strategy."
    example: "When a site returns 429, RelayGate pauses later requests to the same site for a while, then releases them step by step."
    direction: "Separate from patch and render work. It does not mix with response content rewrite."
  wait:
    title: "RelayGate Waiting"
    message: "RelayGate is waiting and retrying: {url}"

patch:
  text:
    model: "The first version now supports both vars and json stages, with pipe as the minimum processing layer."
    example: "YouTube is now driven by patch YAML instead of only hard-coded MITM functions."

render:
  text:
    duty: "Matches a rule from the URL, extracts data, applies a template, and outputs new page content."
    rule: "Do not grow this into a generic rewrite engine. Keep patch and render separate."

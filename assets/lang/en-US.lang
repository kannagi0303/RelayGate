    remove_fail: "Failed to remove CA trust: {error}"
    no_cert: "No local CA certificate file was found. Trust cannot be removed."
    no_diag: "No extra diagnostics are available"
    kept: "RelayGate CA trust was removed from Windows. Local CA files were kept."
    thumb_fail: "Failed to read the local CA thumbprint: {stderr}"
    still:
      diag: "The CA still exists in: {path}; diagnostics: {details}"
      result: "The CA still exists in: {path}; result: {result}; diagnostics: {details}"
      remove: "The CA still exists in: {path}; result: {result}; removal details: {remove_details}; diagnostics: {details}"
      store: "{store_label} still has remaining entries after removal ({stdout})"
